# Template for backend/.env.test — copy to .env.test and fill in.
#
# DATABASE_URL should point to a DEDICATED test database. The test
# suite wipes the cells table in beforeEach, so never point this at
# a database that holds real data.
#
# Provision a ghost.build test database with:
#   ghost create --name cellsite-test --wait --json
# then paste its connection string below.

DATABASE_URL=postgresql://user:pass@host:5432/cellsite_test
NODE_ENV=test
PORT=3000
